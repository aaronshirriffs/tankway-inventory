# MDR Inventory API — required environment variables
#
# Copy to .env and fill in the real values.  NEVER commit the real .env.
#   cp .env.example .env && chmod 600 .env
#
# ---------------------------------------------------------------------------
# Odoo XML-RPC connection (dedicated service account, not a person's login)
# ---------------------------------------------------------------------------
ODOO_URL=https://www.mdrlighting.co.nz
ODOO_DB=your_odoo_database_name
ODOO_USERNAME=system@mdrlighting.co.nz
# An Odoo *API key* (Preferences -> Account Security -> New API Key),
# NOT the account password. XML-RPC accepts the key in the password slot.
ODOO_API_KEY=put_the_odoo_api_key_here

# ---------------------------------------------------------------------------
# Shared session secret — SSO with the Tankway Tools hub
# ---------------------------------------------------------------------------
# On the live server this is NOT set here: it lives once in
# /etc/tankway/shared.env, which the systemd unit loads for both the hub and
# this app so the session cookie is valid across them. Listed for completeness
# — if you run this app standalone, set a long random value.
# TANKWAY_SECRET_KEY=long_random_string
